{
  "permissions": {
    "allow": [
      "Bash(awk:*)",
      "Bash(cat:*)",
      "Bash(docker:*)",
      "Bash(find:*)",
      "Bash(gh:*)",
      "Bash(git:*)",
      "Bash(grep:*)",
      "Bash(ls:*)",
      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(pbcopy:*)",
      "Bash(pnpm:*)",
      "Bash(rg:*)",
      "Bash(tsc:*)",
      "Bash(xargs:*)",
      "Bash(yarn:*)",
      "Edit",
      "Glob",
      "Grep",
      "MultiEdit",
      "Read",
      "Write",
      "mcp__playwright__*",
      "mcp__atlassian__*"
    ],
    "deny": [
      "Read(node_modules/**)",
      "Read(build/**)",
      "Read(dist/**)",
      "Read(.env*)"
    ],
    "defaultMode": "auto"
  },
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true,
  "agentPushNotifEnabled": true,
  "inputNeededNotifEnabled": true
}
